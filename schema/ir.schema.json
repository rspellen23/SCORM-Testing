{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.org/course-ir/v1",
  "title": "Course IR",
  "type": "object",
  "required": ["title", "blocks"],
  "properties": {
    "schema": { "const": "course-ir/v1" },
    "irVersion": { "type": "integer", "minimum": 1, "description": "IR shape version; gated by ir_validate.migrate() on from-ir. Absent = current." },
    "id": { "type": "string" },
    "title": { "type": "string" },
    "locale": { "enum": ["en", "en-GB"] },
    "accent": {
      "type": ["string", "null"],
      "description": "Course accent hex; null = use the active brand's default accent",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    },
    "hero": {
      "type": ["object", "null"],
      "properties": {
        "image": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" }
      }
    },
    "blocks": { "type": "array", "items": { "$ref": "#/definitions/block" } },
    "graded": { "type": "boolean", "description": "scored course: KCs count toward a score; status becomes passed/failed (default false = completion-only, unscored)" },
    "passingScore": { "type": "integer", "minimum": 0, "maximum": 100, "description": "graded only: percent correct required to pass (default 80)" },
    "retry": { "type": "integer", "minimum": 0, "description": "max attempts per knowledge check before it locks + reveals (0 = one-shot). Graded courses score the final answer within the attempts." },
    "_stats": { "type": "object" }
  },
  "definitions": {
    "block": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["heading", "paragraph", "headingParagraph", "image", "imageText",
                   "video", "audio", "embed",
                   "note", "statement", "list", "table", "divider", "continue", "objectives", "knowledgeCheck",
                   "button", "cardGrid",
                   "quote", "accordion", "process", "flashcard", "categorize", "scenario",
                   "timeline", "comparison", "chart", "infographic",
                   "transition", "sectionStart", "sectionEnd"]
        },
        "gated": { "type": "boolean", "description": "Hidden until the preceding continue gate is clicked" },
        "level": { "type": "integer", "minimum": 1, "maximum": 3 },
        "html": { "type": "string", "description": "Inline HTML (strong/em/a/ul/li kept)" },
        "headingHtml": { "type": "string" },
        "variant": { "enum": ["full", "hero", "overlay"] },
        "src": { "type": "string", "description": "assets/<file> path (bundled) or an https URL (embed/streamed)" },
        "alt": { "type": "string" },
        "caption": { "type": "string" },
        "side": { "enum": ["left", "right"] },
        "mode": { "enum": ["file", "embed"], "description": "video: 'file' = self-hosted <video> bundled in the zip; 'embed' = streamed <iframe>" },
        "poster": { "type": "string", "description": "video (file mode): assets/<file> poster frame" },
        "captions": { "type": "string", "description": "video (file mode): assets/<file>.vtt caption track (508/WCAG)" },
        "captionsLang": { "type": "string", "description": "BCP-47 lang for the caption <track> (default 'en')" },
        "transcript": { "type": "string", "description": "audio: full text transcript (collapsible, 508/WCAG)" },
        "title": { "type": "string", "description": "embed/video-embed: iframe accessible title" },
        "aspect": { "type": "string", "description": "embed/video-embed: 'W:H' responsive box (default 16:9)" },
        "height": { "type": "integer", "description": "embed: fixed pixel height (overrides aspect)" },
        "requireComplete": { "type": "boolean", "description": "video(file)/audio only: gate course completion on the media 'ended' event. Ignored for embed (cross-origin, unobservable)." },
        "ordered": { "type": "boolean" },
        "items": { "type": "array", "items": { "type": "string" } },
        "intro": { "type": "string", "description": "objectives: optional lead-in line (default 'After this lesson, you will be able to:')" },
        "text": { "type": "string", "description": "Continue button label" },
        "prompt": { "type": "string" },
        "id": { "type": "string", "description": "knowledgeCheck: stable id, reported as the cmi.interactions id in graded courses" },
        "multi": { "type": "boolean" },
        "feedback": { "type": "string" },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["html", "correct"],
            "properties": {
              "html": { "type": "string" },
              "correct": { "type": "boolean" }
            }
          }
        },

        "label": { "type": "string", "description": "button: visible button label" },
        "buttonVariant": { "enum": ["primary", "secondary"], "description": "button/card link styling" },
        "arrow": { "type": "boolean", "description": "button: append the animated arrow icon" },
        "action": { "enum": ["link", "modal"], "description": "button: 'link' opens href in a new tab; 'modal' opens the bundled modal payload" },
        "href": { "type": "string", "description": "button(action=link)/card link target URL" },
        "requireOpen": { "type": "boolean", "description": "cardGrid: learner must open every modal card before the course can complete (like required media)" },
        "columns": { "type": "integer", "minimum": 1, "maximum": 4, "description": "cardGrid: preferred column count (the grid still reflows to 1 on narrow screens)" },
        "cards": {
          "type": "array",
          "description": "cardGrid: the content cards. A card with a 'modal' expands on click; with only 'link' it is a clickable callout; with neither it is static.",
          "items": {
            "type": "object",
            "required": ["title"],
            "properties": {
              "icon": { "type": "string", "description": "Optional leading glyph or inline <svg> shown above the title" },
              "title": { "type": "string" },
              "teaser": { "type": "string", "description": "Short summary line shown on the card face" },
              "href": { "type": "string", "description": "Clickable-callout target (used when there is no modal)" },
              "modal": { "$ref": "#/definitions/modal" }
            }
          }
        },
        "modal": { "$ref": "#/definitions/modal" },

        "attribution": { "type": "string", "description": "quote: the speaker/source attribution line" },
        "entries": {
          "type": "array",
          "description": "accordion/process/flashcard rows. accordion/process: {title, html, src?, kind?}. flashcard: {frontHtml, frontSrc?, backHtml, backSrc?}.",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "html": { "type": "string" },
              "src": { "type": ["string", "null"], "description": "optional entry image; null/absent means no image" },
              "alt": { "type": "string" },
              "kind": { "enum": ["intro", "step"], "description": "process only: step role" },
              "frontHtml": { "type": "string" },
              "frontSrc": { "type": ["string", "null"] },
              "backHtml": { "type": "string" },
              "backSrc": { "type": ["string", "null"] }
            }
          }
        },
        "buckets": {
          "type": "array",
          "description": "categorize: the target categories",
          "items": {
            "type": "object",
            "required": ["id", "title"],
            "properties": { "id": { "type": "string" }, "title": { "type": "string" } }
          }
        },
        "pool": {
          "type": "array",
          "description": "categorize: the items to sort; each carries its correct bucket id in 'target'",
          "items": {
            "type": "object",
            "required": ["html", "target"],
            "properties": { "html": { "type": "string" }, "target": { "type": "string" } }
          }
        },
        "feedbackIncorrect": { "type": "string", "description": "categorize/knowledgeCheck: feedback shown on a wrong answer" },
        "scenes": {
          "type": "array",
          "description": "scenario (linear fallback): each scene = narrative + response options with feedback",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "html": { "type": "string" },
              "responses": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "html": { "type": "string" },
                    "feedback": { "type": "string" },
                    "preferred": { "type": "boolean" }
                  }
                }
              }
            }
          }
        },
        "accent": { "enum": ["primary", "secondary", "tertiary", "dark"], "description": "timeline/comparison: brand accent role for the block (per-milestone/panel accents are set on each item; omit to auto-cycle)" },
        "milestones": {
          "type": "array",
          "description": "timeline: ordered roadmap milestones rendered along a vertical brand axis (HTML player parity with the 'timeline' slide layout)",
          "items": {
            "type": "object",
            "required": ["title"],
            "properties": {
              "phase": { "type": "string", "description": "phase/date chip, e.g. 'NOW' or 'Q1'" },
              "title": { "type": "string" },
              "html": { "type": "string", "description": "milestone body HTML" },
              "accent": { "enum": ["primary", "secondary", "tertiary", "dark"], "description": "brand accent role for this milestone; omit to auto-cycle" }
            }
          }
        },
        "panels": {
          "type": "array",
          "description": "comparison: 2-3 side-by-side panels for old-vs-new or option A/B/C (HTML player parity with the 'comparison' slide layout)",
          "items": {
            "type": "object",
            "required": ["heading"],
            "properties": {
              "heading": { "type": "string" },
              "sublabel": { "type": "string", "description": "small label under the panel heading" },
              "accent": { "enum": ["primary", "secondary", "tertiary", "dark"], "description": "brand accent role for this panel; omit to auto-cycle" },
              "items": { "type": "array", "items": { "type": "string" }, "description": "panel bullet lines (inline HTML allowed)" },
              "callout": { "type": "string", "description": "highlighted callout box at the foot of the panel" }
            }
          }
        },
        "chart": { "enum": ["bar", "line", "pie", "stackedBar", "groupedBar"], "description": "chart block: visualization type. bar=column comparison; line=trend; pie=part-to-whole; stackedBar/groupedBar=multi-series" },
        "categories": { "type": "array", "items": { "type": "string" }, "description": "chart: x-axis category labels (bar/line/stacked/grouped) or slice labels (pie). One entry per data point per series." },
        "series": {
          "type": "array",
          "description": "chart: one or more data series. pie uses exactly one series. Each series' data length must equal categories length.",
          "items": {
            "type": "object",
            "required": ["data"],
            "properties": {
              "name": { "type": "string", "description": "series legend label (required when >1 series)" },
              "data": { "type": "array", "items": { "type": ["number", "null"] }, "description": "numeric values aligned to categories; null = missing/no-bar" }
            }
          }
        },
        "xLabel": { "type": "string", "description": "chart: x-axis title" },
        "yLabel": { "type": "string", "description": "chart: y-axis (value) title" },
        "source": { "type": "string", "description": "chart: REQUIRED provenance — which source document/table these figures came from. Charts with no source are invalid (no-invented-metrics guardrail)." },
        "infographic": {
          "type": "object",
          "description": "infographic block: a poster-style overview rendered as a flowing HTML section. The content object is IDENTICAL to the 'infographic' slide-layout content schema, so one JSON serves both the slide generator and the course block.",
          "properties": {
            "title": { "type": "string" },
            "subtitle": { "type": "string" },
            "left": {
              "type": "object",
              "description": "the challenge/problem column",
              "properties": {
                "heading": { "type": "string" },
                "intro": { "type": "string" },
                "items": { "type": "array", "description": "bullets; each is either a string or a [bold, detail] pair", "items": {} },
                "callout": { "type": "string" }
              }
            },
            "right": {
              "type": "object",
              "description": "the framework/approach column",
              "properties": {
                "heading": { "type": "string" },
                "sublabel": { "type": "string" },
                "cards": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "num": { "type": "string" },
                      "title": { "type": "string" },
                      "body": { "type": "string" },
                      "accent": { "enum": ["primary", "secondary", "tertiary", "dark"] }
                    }
                  }
                }
              }
            },
            "goals": {
              "type": "object",
              "properties": {
                "label": { "description": "section label — a string or an array of label parts", "items": {} },
                "items": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "title": { "type": "string" },
                      "body": { "type": "string" },
                      "accent": { "enum": ["primary", "secondary", "tertiary", "dark"] }
                    }
                  }
                }
              }
            },
            "footer": { "type": "string" }
          }
        }
      }
    },
    "modal": {
      "type": "object",
      "description": "Bounded modal payload: a heading, ONE media slot, rich text, and an optional link.",
      "properties": {
        "heading": { "type": "string" },
        "html": { "type": "string", "description": "Rich body HTML (strong/em/a/ul/li/p)" },
        "media": {
          "type": "object",
          "properties": {
            "type": { "enum": ["image", "video", "embed"] },
            "src": { "type": "string", "description": "assets/<file> (bundled) or an https URL" },
            "alt": { "type": "string" },
            "mode": { "enum": ["file", "embed"], "description": "video only: 'file' self-hosted vs 'embed' streamed iframe" },
            "poster": { "type": "string" },
            "aspect": { "type": "string", "description": "video(embed)/embed: 'W:H' (default 16:9)" }
          }
        },
        "link": {
          "type": "object",
          "properties": {
            "href": { "type": "string" },
            "label": { "type": "string" }
          }
        }
      }
    }
  }
}
